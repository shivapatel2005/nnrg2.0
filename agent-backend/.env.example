# ─── Required ────────────────────────────────────────────────────────────────
# Get a FREE key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional Overrides ──────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# NNRG website base URL (change only if the domain changes)
NNRG_BASE_URL=https://nnrg.edu.in/

# Max pages fetched per query (higher = more thorough, but slower)
MAX_PAGES_PER_QUERY=6

# Max characters of text kept per fetched document (controls LLM context size)
MAX_CHARS_PER_DOC=6000

# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# Upload directory for PDF files
UPLOAD_DIR=./uploads

# Server port (Render sets this automatically)
PORT=8000

# Allowed frontend origin for CORS (set to your Netlify URL in production)
FRONTEND_URL=http://localhost:3000
